PORT=5000
MONGODB_URI=mongodb://localhost:27017/tritech_hub
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRE=7d

# Email (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=Tritech Hub iOS <your_gmail@gmail.com>

# Paystack
PAYSTACK_SECRET_KEY=sk_live_your_paystack_secret
PAYSTACK_PUBLIC_KEY=pk_live_your_paystack_public
PAYSTACK_WEBHOOK_SECRET=your_webhook_secret

# SimpleMDM
SIMPLEMDM_API_KEY=your_simplemdm_api_key

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880
